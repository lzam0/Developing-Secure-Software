{
  "compilerOptions": {

    /* Project structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Runtime */
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],

    /* Node support */
    "types": ["node"],
    "esModuleInterop": true,

    /* Debugging */
    "sourceMap": true,

    /* Type safety */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Performance */
    "skipLibCheck": true

  },

  "include":[
    "src"
  ]
}